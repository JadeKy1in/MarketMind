{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MCP Sandbox Skills Manifest",
  "description": "Registry for all qualified skills in the Cline OS sandbox environment. Each entry defines interface, trigger conditions, and token cost estimates.",
  "version": "0.1.0",
  "lastUpdated": "2026-05-07",
  "skills": {
    "filesystem": {
      "name": "filesystem",
      "description": "Provides file system operations (read, write, list, search) within allowed sandbox directories.",
      "type": "builtin",
      "status": "active",
      "version": "0.1.0",
      "entryPoint": "mcp_sandbox/skills/filesystem_server/dist/index.js",
      "configSchema": {
        "type": "object",
        "properties": {
          "allowedDirectories": { "type": "array", "items": { "type": "string" } },
          "memoryFile": { "type": "string" }
        },
        "required": ["allowedDirectories"]
      },
      "tokenCost": {
        "read": 100,
        "write": 200,
        "search": 300
      }
    },
    "memory": {
      "name": "memory",
      "description": "Persistent knowledge graph for entities, relations, and observations across sessions.",
      "type": "builtin",
      "status": "active",
      "version": "0.1.0",
      "entryPoint": "mcp_sandbox/skills/memory_server/dist/index.js",
      "configSchema": {
        "type": "object",
        "properties": {
          "memoryFile": { "type": "string" }
        },
        "required": ["memoryFile"]
      },
      "tokenCost": {
        "read": 150,
        "write": 250,
        "search": 200
      }
    }
  },
  "meta": {
    "engineVersion": "0.1.0",
    "scheduledSkills": [],
    "pendingRegistration": []
  }
}